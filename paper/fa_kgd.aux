\@writefile{lot}{\contentsline {table}{\numberline {I}{\ignorespaces Quantitative comparison on fastMRI. Best training-free result per setting in \textbf  {bold}. E2E-VarNet~\cite  {sriram2020varnet} (grey) is a supervised reference that is only available for the brain multicoil setting.}}{4}{table.caption.1}\protected@file@percent }
\newlabel{tab:results}{{I}{4}{Quantitative comparison on fastMRI. Best training-free result per setting in \textbf {bold}. E2E-VarNet~\cite {sriram2020varnet} (grey) is a supervised reference that is only available for the brain multicoil setting}{table.caption.1}{}}
\newlabel{tab:results@cref}{{[table][1][]I}{[1][3][]4}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Qualitative comparison on fastMRI brain ($R{=}4$, $T{=}20$, domain-matched EDM). Columns (left$\to $right): ground truth, $\Pi $GDM, FA-KGD (ours), $|\text  {error}|$ for $\Pi $GDM, $|\text  {error}|$ for FA-KGD. Error maps share the same colour scale. FA-KGD consistently reduces the residual energy concentrated around high-contrast cortical and ventricular edges --- the region where $\Pi $GDM's DC shock manifests as Gibbs ringing. Per-slice PSNR/SSIM are overlaid on the reconstruction panels.}}{4}{figure.caption.2}\protected@file@percent }
\newlabel{fig:recon}{{1}{4}{Qualitative comparison on fastMRI brain ($R{=}4$, $T{=}20$, domain-matched EDM). Columns (left$\to $right): ground truth, $\Pi $GDM, FA-KGD (ours), $|\text {error}|$ for $\Pi $GDM, $|\text {error}|$ for FA-KGD. Error maps share the same colour scale. FA-KGD consistently reduces the residual energy concentrated around high-contrast cortical and ventricular edges --- the region where $\Pi $GDM's DC shock manifests as Gibbs ringing. Per-slice PSNR/SSIM are overlaid on the reconstruction panels}{figure.caption.2}{}}
\newlabel{fig:recon@cref}{{[figure][1][]1}{[1][3][]4}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Scaling with step budget $T$ on brain $R{=}4$ (domain-matched EDM, 5 slices). (a)~$\Delta $PSNR (FA-KGD $-$ $\Pi $GDM) grows monotonically with $T$, reaching $+0.58$~dB at $T{=}100$. (b)~Absolute PSNR: $\Pi $GDM peaks at $T{=}50$ and slightly degrades afterwards, while FA-KGD remains flat --- consistent with our hypothesis that FPDC eliminates the over-correction mode that drives $\Pi $GDM's late-$T$ regression. (c)~SSIM follows the same trend.}}{4}{figure.caption.3}\protected@file@percent }
\newlabel{fig:scaling}{{2}{4}{Scaling with step budget $T$ on brain $R{=}4$ (domain-matched EDM, 5 slices). (a)~$\Delta $PSNR (FA-KGD $-$ $\Pi $GDM) grows monotonically with $T$, reaching $+0.58$~dB at $T{=}100$. (b)~Absolute PSNR: $\Pi $GDM peaks at $T{=}50$ and slightly degrades afterwards, while FA-KGD remains flat --- consistent with our hypothesis that FPDC eliminates the over-correction mode that drives $\Pi $GDM's late-$T$ regression. (c)~SSIM follows the same trend}{figure.caption.3}{}}
\newlabel{fig:scaling@cref}{{[figure][2][]2}{[1][3][]4}{}{}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {\mbox  {V-E}}Cross-Domain Generalization}{4}{subsection.5.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Per-band k-space NMSE on brain $R=4$ computed from real reconstructions (5 slices). (a)~Absolute NMSE by radial frequency band. (b)~Relative improvement over $\Pi $GDM per band. FA-KGD gains are concentrated in the low-frequency bands ($+9.1$\% at 0–50, $+8.7$\% at 50–100) and are negligible at high frequencies, consistent with the FPDC mechanism that defers high-frequency DC to later denoising steps.}}{4}{figure.caption.4}\protected@file@percent }
\newlabel{fig:freq}{{3}{4}{Per-band k-space NMSE on brain $R=4$ computed from real reconstructions (5 slices). (a)~Absolute NMSE by radial frequency band. (b)~Relative improvement over $\Pi $GDM per band. FA-KGD gains are concentrated in the low-frequency bands ($+9.1$\% at 0–50, $+8.7$\% at 50–100) and are negligible at high frequencies, consistent with the FPDC mechanism that defers high-frequency DC to later denoising steps}{figure.caption.4}{}}
\newlabel{fig:freq@cref}{{[figure][3][]3}{[1][3][]4}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Cross-domain comparison across the four fastMRI settings reported in \Cref  {tab:results}. (a)~$\Delta $PSNR and (b)~$\Delta $SSIM relative to $\Pi $GDM. FA-KGD improves over $\Pi $GDM in every configuration. Domain-matched brain experiments (blue) show 2--3$\times $ larger PSNR gains than cross-domain knee experiments (orange), consistent with the adaptive gain benefiting from an accurate score prior; SSIM gains are comparable across domains.}}{4}{figure.caption.5}\protected@file@percent }
\newlabel{fig:crossdomain}{{4}{4}{Cross-domain comparison across the four fastMRI settings reported in \Cref {tab:results}. (a)~$\Delta $PSNR and (b)~$\Delta $SSIM relative to $\Pi $GDM. FA-KGD improves over $\Pi $GDM in every configuration. Domain-matched brain experiments (blue) show 2--3$\times $ larger PSNR gains than cross-domain knee experiments (orange), consistent with the adaptive gain benefiting from an accurate score prior; SSIM gains are comparable across domains}{figure.caption.5}{}}
\newlabel{fig:crossdomain@cref}{{[figure][4][]4}{[1][4][]4}{}{}{}}
