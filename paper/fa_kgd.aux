\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Hyperparameter sweep on brain $R{=}4$. $\Delta $PSNR (dB) relative to $\Pi $GDM as a function of FPDC exponent $\beta $ and EMA smoothing $\alpha $ (12 configurations, 5 slices each). The best configuration ($\beta {=}1.0$, $\alpha {=}0.95$, $\Delta {=}+0.315$~dB) is highlighted; all 12 settings improve over $\Pi $GDM. Performance is relatively flat for $\beta \!\in \!\{0.5, 1.0\}$ and degrades at $\beta {=}2.0$, indicating that the existence of a progressive schedule matters more than its exact shape.}}{5}{figure.caption.6}\protected@file@percent }
\newlabel{fig:hparam}{{5}{5}{Hyperparameter sweep on brain $R{=}4$. $\Delta $PSNR (dB) relative to $\Pi $GDM as a function of FPDC exponent $\beta $ and EMA smoothing $\alpha $ (12 configurations, 5 slices each). The best configuration ($\beta {=}1.0$, $\alpha {=}0.95$, $\Delta {=}+0.315$~dB) is highlighted; all 12 settings improve over $\Pi $GDM. Performance is relatively flat for $\beta \!\in \!\{0.5, 1.0\}$ and degrades at $\beta {=}2.0$, indicating that the existence of a progressive schedule matters more than its exact shape}{figure.caption.6}{}}
\newlabel{fig:hparam@cref}{{[figure][5][]5}{[1][5][]5}{}{}{}}
